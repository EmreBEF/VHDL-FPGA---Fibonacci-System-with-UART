library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.STD_LOGIC_signed.ALL;
use WORK.ALL;
entity Fibo_carry is
 port ( Clk : in std_logic;
 Raz : in std_logic; -- Reset du circuit
 EN : in std_logic; -- Validation du circuit
 N : in std_logic_vector (6 downto 0); -- nombre de terme a generer
 Suite : out std_logic_vector (7 downto 0); -- sortie du generateur de nombre
 Carry_flag : out std_logic
 );
end Fibo_carry;
architecture behavioral of Fibo_carry is
begin
 process
 variable terme : std_logic_vector (7 downto 0); -- terme actuel
 variable terme_1 : std_logic_vector (7 downto 0); -- dernier terme
 variable terme_2 : std_logic_vector (7 downto 0); -- avant dernier terme
 variable compt : std_logic_vector (6 downto 0); -- compteur du nombre de terme
 variable overflow : std_logic; -- flag de debordement

 begin

 wait until CLK'event and CLK='1';

 if ( RaZ = '0') then
 compt:="00000000";
 terme := "00000001";
 terme_1 := "00000001";
 terme_2 := "00000000";
 overflow := '0';
else if En='1' then
-- Suite de la description

 end process;
end;
