LIBRARY ieee;
USE ieee.std_logic_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

ENTITY USART IS
		PORT(Clk, RAZ, StartTr: in std_logic:='0';
			  DataIn: in std_logic_vector(7 DOWNTO 0);
			  TxD: out std_logic
			  );
END ENTITY USART;

ARCHITECTURE behavior OF USART IS
		TYPE etat_type IS(IDLE,START,DATA,STOP);
		SIGNAL etat_present, etat_suivant: etat_type;
BEGIN
RE: PROCESS(Clk, RAZ)
		BEGIN
		IF RAZ='1' THEN etat_present <= IDLE;
		ELSIF Clk'event and Clk= '1'THEN 
						etat_present <= IDLE;
		END IF;
END PROCESS;