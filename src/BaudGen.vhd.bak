library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity BaudGen is
    port(
        CLK    : in  std_logic;
        VITESSE    : in  std_logic;
        BaudEn : out std_logic
    );
end BaudGen;

architecture behavior of BaudGen is
begin

    process(CLK)
        variable compt : unsigned(13 downto 0);
	
    begin
        if rising_edge(CLK) then
		  
            if VITESSE = '0' then
				compt := (others => '0');
				
                if compt = to_unsigned(2605, 13) then
						  BaudEn <= '1';
						  compt:= (others => '0');
                else
                    BaudEn <= '0';
                    compt := compt1 + 1;
						  
				if VITESSE = '1' then
				compt := (others => '0')
				
					 if compt = to_unsigned(5208, 13) then
							BaudEn <= '1';
							compt:= (others => '0');
					 else
                    BaudEn <= '0';
                    compt := compt1 + 1;
							
						  
                end if;
            end if;
				end if;
				end if;
        end if;
    end process;

end behavior;

