library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use WORK.ALL;

ENTITY Assemblage_V1 IS
	PORT(
			En,RAZ,CLK: IN STD_LOGIC;
			N: IN STD_LOGIC_VECTOR(6 downto 0);
			unite: out STD_LOGIC_VECTOR(6 downto 0);
			dizaine: out STD_LOGIC_VECTOR(6 downto 0);
			centaine: out STD_LOGIC_VECTOR(6 downto 0);
			millier: out STD_LOGIC_VECTOR(6 downto 0);
			Carry out STD_LOGIC );
	END Assemblage_V1;
	
ARCHITECTURE structur OF top IS

	SIGNAL data : STD_LOGIC_vector (15 downto 0);

COMPONENT Fibo_carry
		port( 
				Clk : in std_logic;
				Raz : in std_logic; -- Reset du circuit
				EN : in std_logic; -- Validation du circuit
				N : in std_logic_vector (6 downto 0); -- nombre de terme a generer
				Suite : out std_logic_vector (7 downto 0); -- sortie du generateur de nombre
				Carry_flag : out std_logic );
END COMPONENT;

COMPONENT seven_seg
		PORT(
				in4 : in std_logic_vector (3 downto 0); -- nombre binaire d'entre
				seg7 : out std_logic_vector (6 downto 0) ); -- code 7 segment
END COMPONENT;

BEGIN -- description structurelle
 fib1: Fibo_carry PORT MAP (Clk,Raz,EN,N,data);
 dec_0: seven_seg PORT MAP (data(3 downto 0),unite);
 dec_1: seven_seg PORT MAP (data(7 downto 4),dizaine);
 dec_2: seven_seg PORT MAP (data(11 downto 8)
 
END structur;
